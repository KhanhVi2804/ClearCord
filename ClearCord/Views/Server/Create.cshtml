@model ClearCord.Models.Server

<div class="row justify-content-center">
    <div class="col-md-4 mt-5">
        <div class="card shadow border-0 bg-dark text-white">
            <div class="card-body p-4 text-center">
                <h3 class="fw-bold">Tùy chỉnh máy chủ của bạn</h3>
                <p class="text-secondary">Hãy đặt cho máy chủ mới một cái tên. Bạn luôn có thể thay đổi nó sau.</p>
                
                <form asp-action="Create">
                    <div class="mb-3 text-start">
                        <label class="form-label fw-bold">TÊN MÁY CHỦ</label>
                        <input asp-for="Name" class="form-control bg-secondary text-white border-0" placeholder="Máy chủ của @Context.Session.GetString("Username")" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Index" class="text-white text-decoration-none">Quay lại</a>
                        <button type="submit" class="btn btn-primary px-4">Tạo máy chủ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>