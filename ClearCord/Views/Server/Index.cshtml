@model IEnumerable<ClearCord.Models.Server>
@{
    ViewData["Title"] = "Máy chủ";
    // Ép kiểu dữ liệu từ ViewBag
    var channels = ViewBag.Channels as List<ClearCord.Models.Channel>;
    var currentServerId = ViewBag.CurrentServerId;
    var currentChannelId = ViewBag.CurrentChannelId;
    var channelName = ViewBag.ChannelName ?? "chung";
}

<style>
    .main-wrapper {
        display: flex;
        height: 92vh;
        margin-top: -1rem;
    }
    /* Cột 1: Servers */
    .server-sidebar {
        width: 72px;
        background-color: #1E1F22;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 12px;
        overflow-y: auto;
    }
    /* Cột 2: Channels */
    .channel-sidebar {
        width: 240px;
        background-color: #2B2D31;
        color: #949BA4;
        padding: 15px;
    }
    /* Cột 3: Chat Area */
    .chat-area {
        flex: 1;
        background-color: #313338;
        color: white;
        display: flex;
        flex-direction: column;
    }

    .server-icon {
        width: 48px;
        height: 48px;
        background-color: #313338;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 8px;
        color: white;
        text-decoration: none;
        transition: 0.2s;
    }

        .server-icon:hover, .server-icon.active {
            border-radius: 30%;
            background-color: #5865F2;
        }

    .channel-item {
        padding: 6px 10px;
        border-radius: 4px;
        cursor: pointer;
        transition: 0.2s;
        text-decoration: none;
        display: block;
        color: #949BA4;
        margin-bottom: 2px;
    }

        .channel-item:hover {
            background-color: #35373C;
            color: #DBDEE1;
        }

        .channel-item.active {
            background-color: #3F4147;
            color: white;
        }
</style>

<div class="main-wrapper">
    <div class="server-sidebar">
        <a asp-controller="Home" asp-action="Index" class="server-icon" title="Trang chủ">
            <i class="fa-solid fa-ghost"></i>
        </a>
        <hr style="width: 32px; border-top: 2px solid #35363C; margin: 8px 0;">

        @foreach (var server in Model)
        {
            <a asp-action="Index" asp-route-id="@server.Id"
               class="server-icon @(currentServerId != null && (int)currentServerId == server.Id ? "active" : "")"
               title="@server.Name">
                @server.Name.Substring(0, 1).ToUpper()
            </a>
        }

        <a asp-action="Create" class="server-icon text-success" title="Thêm máy chủ">
            <i class="fa-solid fa-plus"></i>
        </a>
    </div>

    <div class="channel-sidebar">
        <h6 class="text-white mb-3 text-uppercase small fw-bold">
            @(ViewBag.ServerName ?? "DANH SÁCH KÊNH")
        </h6>

        @if (channels != null && channels.Any())
        {
            @foreach (var ch in channels)
            {
                <a asp-action="Index"
                   asp-route-id="@currentServerId"
                   asp-route-channelId="@ch.Id"
                   class="channel-item @(currentChannelId != null && (int)currentChannelId == ch.Id ? "active" : "")">
                    <i class="fa-solid fa-hashtag me-2"></i> @ch.Name
                </a>
            }
        }
        else
        {
            <div class="small text-muted italic p-2">Chọn máy chủ để xem kênh</div>
        }
    </div>

    <div class="chat-area">
        <div class="p-3 border-bottom border-dark shadow-sm">
            <strong><i class="fa-solid fa-hashtag me-2 text-secondary"></i> @channelName</strong>
        </div>

        <div class="flex-grow-1 p-3 overflow-auto" id="message-box" style="max-height: 75vh;">
            <div class="mb-3">
                <span class="text-info fw-bold">Hệ thống:</span>
                <span class="text-secondary small">Chào mừng bạn đến với kênh #@channelName!</span>
            </div>
        </div>

        <div class="p-3">
            <div class="input-group">
                <input type="text" id="messageInput" class="form-control bg-secondary text-white border-0 py-2"
                       placeholder="Nhắn tin tới #@channelName" style="background-color: #383A40 !important;">
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
<script>
    var connection = new signalR.HubConnectionBuilder().withUrl("/chatHub").build();

    connection.on("ReceiveMessage", function (user, message) {
        var msgBox = document.getElementById("message-box");
        var div = document.createElement("div");
        div.classList.add("mb-2");
        div.innerHTML = `<span class="text-info fw-bold">${user}:</span> <span class="text-white">${message}</span>`;
        msgBox.appendChild(div);
        msgBox.scrollTop = msgBox.scrollHeight;
    });

    connection.start().catch(function (err) {
        return console.error(err.toString());
    });

    document.getElementById("messageInput").addEventListener("keypress", function (e) {
        if (e.key === "Enter") {
            var message = this.value;
            var user = "@Context.Session.GetString("Username")" || "User";

            if (message.trim() !== "") {
                connection.invoke("SendMessage", user, message).catch(function (err) {
                    return console.error(err.toString());
                });
                this.value = "";
            }
        }
    });
</script>